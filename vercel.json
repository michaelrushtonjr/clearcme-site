{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/email-reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/monthly-digest",
      "schedule": "0 15 1 * *"
    }
  ]
}
