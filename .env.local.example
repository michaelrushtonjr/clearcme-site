# Copy to .env.local and fill in values

# Email capture (add your provider of choice — Resend, Mailchimp, ConvertKit, etc.)
WAITLIST_API_KEY=

# Stripe (for future payment integration)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel Blob — for storing uploaded certificate files
# Get this from Vercel dashboard → Storage → Blob → your store → .env.local button
BLOB_READ_WRITE_TOKEN=

# Vercel Cron — renewal reminder push notifications
# Generate with: openssl rand -hex 32
# Add this to Vercel environment variables too (Settings → Environment Variables)
CRON_SECRET=your-secret-here
